<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="D:/DATA ANALYIS PROJECT/E-Commerce Sales Data Analysis/ecommerce.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser query pragmas" current="2"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1752"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Sales_data" custom_title="0" dock_id="1" table="4,10:mainSales_data"/><dock_state state="000000ff00000000fd000000010000000200000362000002a6fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000003620000012d00ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Sales_data" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="54"/><column index="2" value="117"/><column index="3" value="85"/><column index="4" value="85"/><column index="5" value="117"/><column index="6" value="93"/><column index="7" value="163"/><column index="8" value="93"/><column index="9" value="109"/><column index="10" value="132"/><column index="11" value="117"/><column index="12" value="93"/><column index="13" value="62"/><column index="14" value="124"/><column index="15" value="124"/><column index="16" value="101"/><column index="17" value="300"/><column index="18" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT * FROM sales LIMIT 10;

SELECT region, SUM(sales)
FROM sales
GROUP BY region;

---Top 10 States by Sales

SELECT 
state,
SUM(sales) AS total_sales
FROM sales
GROUP BY state
ORDER BY total_sales DESC
LIMIT 10;

---Top 10 Cities by Profit

SELECT 
city,
SUM(profit) AS total_profit
FROM sales
GROUP BY city
ORDER BY total_profit DESC
LIMIT 10;

---Average Discount by Category

SELECT 
category,
AVG(discount) AS avg_discount
FROM sales
GROUP BY category;

---Total Quantity Sold by Category

SELECT 
category,
SUM(quantity) AS total_quantity
FROM sales
GROUP BY category
ORDER BY total_quantity DESC;

---Profit Margin by Category

SELECT 
category,
SUM(profit) AS total_profit,
SUM(sales) AS total_sales,
(SUM(profit) / SUM(sales)) * 100 AS profit_margin
FROM sales
GROUP BY category
ORDER BY profit_margin DESC;

---Region with Highest Average Sales

SELECT 
region,
AVG(sales) AS avg_sales
FROM sales
GROUP BY region
ORDER BY avg_sales DESC;

---Sub-Category with Highest Profit

SELECT 
sub_category,
SUM(profit) AS total_profit
FROM sales
GROUP BY sub_category
ORDER BY total_profit DESC
LIMIT 5;

---Sub-Categories Making Loss

SELECT 
sub_category,
SUM(profit) AS total_profit
FROM sales
GROUP BY sub_category
HAVING total_profit &lt; 0
ORDER BY total_profit;

---Most Used Ship Mode

SELECT 
ship_mode,
COUNT(*) AS total_orders
FROM sales
GROUP BY ship_mode
ORDER BY total_orders DESC;

---Segment Contribution to Sales

SELECT 
segment,
SUM(sales) AS total_sales
FROM sales
GROUP BY segment
ORDER BY total_sales DESC;

---Profit by Region

SELECT 
region,
SUM(profit) AS total_profit
FROM sales
GROUP BY region
ORDER BY total_profit DESC;

---Top 10 Highest Sales Orders

SELECT *
FROM sales
ORDER BY sales DESC
LIMIT 10;

---Rank Cities by Sales

SELECT 
city,
SUM(sales) AS total_sales,
RANK() OVER (ORDER BY SUM(sales) DESC) AS sales_rank
FROM sales
GROUP BY city;

---Top 3 Cities by Profit

SELECT *
FROM (
SELECT 
city,
SUM(profit) AS total_profit,
RANK() OVER (ORDER BY SUM(profit) DESC) AS profit_rank
FROM sales
GROUP BY city
)
WHERE profit_rank &lt;= 3;

---Running Total of Sales

SELECT 
city,
sales,
SUM(sales) OVER (ORDER BY sales) AS running_total
FROM sales;

---Sales Contribution Percentage by Category

SELECT 
category,
SUM(sales) AS total_sales,
ROUND(
SUM(sales) * 100.0 /
(SELECT SUM(sales) FROM sales), 2
) AS percentage_contribution
FROM sales
GROUP BY category;

---Average Profit by Region

SELECT 
region,
AVG(profit) AS avg_profit
FROM sales
GROUP BY region
ORDER BY avg_profit DESC;

---Find Orders with Profit Above Average

SELECT *
FROM sales
WHERE profit &gt; (
SELECT AVG(profit)
FROM sales
);

---Top Sub-Category in Each Category

SELECT *
FROM (
SELECT 
category,
sub_category,
SUM(sales) AS total_sales,
RANK() OVER (
PARTITION BY category
ORDER BY SUM(sales) DESC
) AS rank_in_category
FROM sales
GROUP BY category, sub_category
)
WHERE rank_in_category = 1;

---Discount Impact on Profit

SELECT 
discount,
AVG(profit) AS avg_profit,
SUM(sales) AS total_sales
FROM sales
GROUP BY discount
ORDER BY discount;

---Most Profitable State

SELECT 
state,
SUM(profit) AS total_profit
FROM sales
GROUP BY state
ORDER BY total_profit DESC
LIMIT 5;

---Sales Distribution by Ship Mode

SELECT 
ship_mode,
SUM(sales) AS total_sales,
SUM(profit) AS total_profit
FROM sales
GROUP BY ship_mode
ORDER BY total_sales DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
